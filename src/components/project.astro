---
import { Github, ArrowUpRight } from "@lucide/astro";
import { Image } from "astro:assets";
import T from "@/components/T.astro";

interface Props {
  name: string;
  url: string;
  githubUrl: string;
  year: string;
  descriptionKey: string;
  imageSrc: any;
}

const { name, url, githubUrl, year, descriptionKey, imageSrc } = Astro.props;
---

<div class="border-2 border-foreground bg-card">
  <Image
    src={imageSrc}
    alt={name}
    width="2048"
    class="w-full h-[200px] object-cover object-top border-b"
    layout="constrained"
  />
  <div class="p-4">
    <div class="flex items-center gap-4">
      <a class="font-semibold flex-1" href={url} target="_blank">
        <span class="underline">{name}</span>
        <ArrowUpRight size={16} class="inline" />
      </a>
      <div class="text-gray-500 text-sm">{year}</div>
      <a href={githubUrl} target="_blank" aria-label="View GitHub repository">
        <Github size={14} />
      </a>
    </div>
    <T key={descriptionKey} class="text-sm" />
  </div>
</div>
