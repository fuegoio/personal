---
import { Github, ArrowUpRight } from "@lucide/astro";
import T from "@/components/T.astro";

interface Props {
  name: string;
  url: string;
  githubUrl: string;
  year: string;
  descriptionKey: string;
}

const { name, url, githubUrl, year, descriptionKey } = Astro.props;
---

<div class="border border-foreground bg-card">
  <div class="p-4">
    <div class="flex items-center gap-4">
      <a class="font-semibold flex-1" href={url} target="_blank">
        <span class="underline">{name}</span>
        <ArrowUpRight size={16} class="inline" />
      </a>
      <div class="text-gray-500 text-sm">{year}</div>
      <a href={githubUrl} target="_blank" aria-label="View GitHub repository">
        <Github size={14} />
      </a>
    </div>
    <T key={descriptionKey} class="text-sm" />
  </div>
</div>
